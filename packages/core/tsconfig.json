{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "paths": {
      "@nextpress/db": ["../db/src"],
      "@nextpress/db/*": ["../db/src/*"],
      "@nextpress/blocks": ["../blocks/src"],
      "@nextpress/blocks/*": ["../blocks/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist", "src/__tests__"]
}
